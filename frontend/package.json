{
    "name": "frontend-crewai",
    "version": "0.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve --no-hmr",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "build-mym": "ng build --base-href /epicstaff/",
        "prepare": "cd .. && npx husky frontend/.husky",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "format": "prettier --write \"src/**/*.{ts,html,scss,json}\""
    },
    "lint-staged": {
        "src/**/*.ts": [
            "eslint --fix --max-warnings=0",
            "prettier --write"
        ],
        "src/**/*.html": [
            "prettier --write"
        ],
        "src/**/*.scss": [
            "prettier --write"
        ]
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^19.2.0",
        "@angular/cdk": "^19.2.0",
        "@angular/common": "^19.2.0",
        "@angular/compiler": "^19.2.0",
        "@angular/core": "^19.2.0",
        "@angular/forms": "^19.2.0",
        "@angular/material": "^19.2.0",
        "@angular/platform-browser": "^19.2.0",
        "@angular/platform-browser-dynamic": "^19.2.0",
        "@angular/router": "^19.2.0",
        "@astral-sh/ruff-wasm-web": "^0.15.2",
        "@foblex/2d": "1.2.2",
        "@foblex/flow": "18.4.0",
        "@foblex/mediator": "1.1.3",
        "@foblex/platform": "1.0.4",
        "@foblex/utils": "1.1.1",
        "@openai/realtime-api-beta": "github:openai/openai-realtime-api-beta",
        "@tabler/icons": "^3.34.0",
        "ag-grid-angular": "^33.1.1",
        "ag-grid-community": "^33.1.1",
        "lodash-es": "^4.18.0",
        "monaco-editor": "^0.52.2",
        "ngx-color": "^10.0.0",
        "ngx-json-viewer": "^3.2.1",
        "ngx-markdown": "^19.1.0",
        "ngx-monaco-editor-v2": "^19.0.2",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0",
        "uuid": "^11.0.5",
        "wavtools": "^0.1.5",
        "zone.js": "~0.15.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^19.2.0",
        "@angular-eslint/eslint-plugin": "^19.8.1",
        "@angular/cli": "^19.2.0",
        "@angular/compiler-cli": "^19.2.0",
        "@types/jasmine": "~5.1.0",
        "@types/lodash": "^4.17.14",
        "@types/lodash-es": "^4.17.12",
        "eslint": "^9.39.4",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "husky": "^9.1.7",
        "jasmine-core": "~5.2.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.1.0",
        "lint-staged": "^16.3.3",
        "prettier": "^3.8.1",
        "puppeteer": "^23.7.1",
        "typescript": "~5.5.2",
        "typescript-eslint": "^8.57.0"
    }
}
