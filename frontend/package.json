{
  "name": "frontend-crewai",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --no-hmr",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build-mym": "ng build --base-href /epicstaff/",
    "prepare": "cd .. && npx husky frontend/.husky",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\""
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.html": [
      "prettier --write"
    ],
    "src/**/*.scss": [
      "prettier --write"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.17",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.17",
    "@angular/compiler": "21.2.17",
    "@angular/core": "21.2.17",
    "@angular/forms": "21.2.17",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.17",
    "@angular/platform-browser-dynamic": "21.2.17",
    "@angular/router": "21.2.17",
    "@astral-sh/ruff-wasm-web": "0.15.2",
    "@foblex/2d": "1.2.2",
    "@foblex/flow": "18.4.0",
    "@foblex/mediator": "1.1.3",
    "@foblex/platform": "1.0.4",
    "@foblex/utils": "1.1.1",
    "@openai/realtime-api-beta": "github:openai/openai-realtime-api-beta#a5cb94824f625423858ebacb9f769226ca98945f",
    "@tabler/icons": "3.36.1",
    "ag-grid-angular": "33.3.2",
    "ag-grid-community": "33.3.2",
    "lodash-es": "4.18.0",
    "mammoth": "1.12.0",
    "monaco-editor": "0.55.1",
    "ngx-color": "10.1.0",
    "ngx-image-cropper": "9.1.6",
    "ngx-json-viewer": "3.2.1",
    "ngx-markdown": "21.3.0",
    "ngx-monaco-editor-v2": "21.1.4",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "uuid": "11.1.0",
    "wavtools": "0.1.5",
    "xlsx": "0.18.5",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular/build": "^21.2.16",
    "@angular/cli": "^21.2.16",
    "@angular/compiler-cli": "^21.2.17",
    "@types/jasmine": "~5.1.0",
    "@types/lodash-es": "^4.17.12",
    "eslint": "^9.39.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jasmine-core": "~5.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "puppeteer": "^23.7.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
