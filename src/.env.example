# EpicStaff environment configuration.
# Copy to `.env`, fill in the marked secrets, then `docker compose up -d`.
#
# Lines marked CHANGE ME must be set before first run.
# Everything else has sensible defaults that work for a local install.

# ===== SHARED =====
# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                          # CHANGE ME (any non-empty string)

# Database configuration
POSTGRES_DB=crew
POSTGRES_PASSWORD=                       # CHANGE ME (postgres superuser password)
PGDATA=/var/lib/postgresql/data
DB_HOST_NAME=crewdb
DB_NAME=crew
DB_PORT=5432
DB_USER=postgres

# Volumes
DOCKER_SOCK_PATH=/var/run/docker.sock
DOCKER_BIN_PATH=/usr/bin/docker
# ==================

# ==== SERVICES ====

# django_app
DEBUG=False
SECRET_KEY=                              # CHANGE ME (Django SECRET_KEY; generate a 50+ char random string)
JWT_SECRET=                              # CHANGE ME (≥32 char random string for JWT signing)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
# RBAC bootstrap — True to auto-create on startup, False to use
# POST /api/auth/first-setup/ instead.
DJANGO_AUTO_CREATE_ADMIN=False
DJANGO_ADMIN_EMAIL=admin@example.com
DJANGO_ADMIN_PASSWORD=                   # CHANGE ME (only used when DJANGO_AUTO_CREATE_ADMIN=True)
DEFAULT_ORGANIZATION_NAME=Organization
PASSWORD_RESET_TOKEN_TTL=900
PASSWORD_RESET_REQUEST_THROTTLE_RATE=5/hour
# SMTP — leave EMAIL_HOST/USER/PASSWORD blank to fall back to the console email backend.
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@epicstaff.local
FRONTEND_BASE_URL=http://localhost:4200
FRONTEND_PASSWORD_RESET_PATH=/reset-password
PASSWORD_CHANGE_TICKET_TTL_SECONDS=300
AVATAR_MAX_BYTES=5242880
AVATAR_ALLOWED_FORMATS=JPEG,PNG
# Internal-service API key (no owner). Must match across services.
DJANGO_API_KEY=                          # CHANGE ME (any random string)
ALLOWED_HOSTS=0.0.0.0,127.0.0.1,localhost,django_app
GUNICORN_WORKERS=1
GUNICORN_THREADS=4
MEDIA_ROOT=/app/media
DJANGO_HOST=localhost
DJANGO_PORT=8000
LOAD_DEBUG_ENV=False
# Memory tuning
MALLOC_ARENA_MAX=2
MALLOC_TRIM_INTERVAL_SECONDS=60

# Gunicorn
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100

# realtime
DB_REALTIME_USER=realtime_user
DB_REALTIME_PASSWORD=                    # CHANGE ME (postgres role password for realtime service)
REALTIME_PORT=8050
DJANGO_AUTH_URL=http://django_app:8000
DJANGO_AUTH_TIMEOUT=5

# manager
PULL_TOOL=False
DB_MANAGER_USER=manager_user
DB_MANAGER_PASSWORD=                     # CHANGE ME (postgres role password for manager service)
# CREW_SAVEFILES_PATH must be an absolute host path. Linux/macOS: e.g. /home/<you>/savefiles.
# Windows + Docker Desktop: /c/savefiles. Override per-OS in the install command.
CREW_SAVEFILES_PATH=/c/savefiles
MANAGER_HOST=manager_container
MANAGER_PORT=8001

# crew
HAYSTACK_TELEMETRY_ENABLED=False
ANONYMIZED_TELEMETRY=False
EC_TELEMETRY=False
MONITORING_MODE=local
DB_CREW_USER=crew_user
DB_CREW_PASSWORD=                        # CHANGE ME (postgres role password for crew service)
MAX_CONCURRENT_SESSIONS=25

# sandbox
BASE_VENV_PATH=/app/src/sandbox/venvs/
OUTPUT_PATH=/app/src/sandbox/executions/
CONTAINER_SAVEFILES_PATH=/app/src/sandbox/savefiles/

# knowledge
DB_KNOWLEDGE_USER=knowledge_user
DB_KNOWLEDGE_PASSWORD=                   # CHANGE ME (postgres role password for knowledge service)

# webhook
WEBHOOK_HOST_NAME=webhook
USE_TUNNEL=False
WEBHOOK_TUNNEL=NGROK
WEBHOOK_AUTH=
WEBHOOK_PORT=8009
# Ngrok (only used when USE_TUNNEL=True and WEBHOOK_TUNNEL=NGROK)
NGROK_AUTHTOKEN=
NGROK_DOMAIN=

# code
CODE_MANAGER_PORT=4080
CODE_BASE_PORT=4096
CODE_MAX_INSTANCES=5
CODE_IDLE_TIMEOUT=300
CODE_REAP_INTERVAL=30
CODE_INSTANCES_DIR=/opt/opencode/instances

# frontend
FRONTEND_PORT=4200
API_URL=http://127.0.0.1:8000/api/
REALTIME_API_URL=http://127.0.0.1:8050/realtime/

# nginx
DOMAIN_NAME=localhost
# SSL_ENABLE=#  <-- # disables ssl
# SSL_ENABLE=   <-- empty enables ssl
SSL_ENABLE=#

# storage
STORAGE_BACKEND=s3
STORAGE_LOCAL_ROOT=/app/storage
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=                      # CHANGE ME (minio secret, ≥8 chars)
STORAGE_BUCKET_NAME=epicstaff
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
