# --- Stage 1: Builder ---
FROM python:3.12.10-slim@sha256:fd95fa221297a88e1cf49c55ec1828edd7c5a428187e67b5d1805692d11588db AS builder

ENV POETRY_VIRTUALENVS_IN_PROJECT=true \
    POETRY_NO_INTERACTION=1 \
    POETRY_CACHE_DIR=/tmp/poetry_cache \
    POETRY_REQUESTS_TIMEOUT=100 \
    PIP_DISABLE_PIP_VERSION_CHECK=on \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app/src

# Install pip tools and pinned Poetry
RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir "poetry==2.4.1"

# Copy only dependency descriptors first (better caching)
COPY ./agent/pyproject.toml ./agent/poetry.lock ./agent/

WORKDIR /app/src/agent

# Install dependencies inside project .venv
RUN poetry install --no-ansi --no-root --without dev

# Copy application source
COPY ./agent /app/src/agent
COPY ./shared /app/src/shared

# --- Stage 2: Runtime ---
FROM python:3.12.10-slim@sha256:fd95fa221297a88e1cf49c55ec1828edd7c5a428187e67b5d1805692d11588db AS runtime

RUN pip install --no-cache-dir "poetry==2.4.1"

# Copy built app from builder
COPY --from=builder /app /app

# Create non-root user for runtime
RUN groupadd --system --gid 1000 app \
 && useradd  --system --uid 1000 --gid app --create-home --shell /usr/sbin/nologin app \
 && chown -R app:app /app

# Add virtualenv to PATH
ENV PATH="/app/src/agent/.venv/bin:$PATH" \
    PYTHONPATH=/app/src \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    VIRTUAL_ENV=/app/src/agent/.venv

WORKDIR /app/src/agent

USER app

CMD ["poetry", "run", "python3", "/app/src/agent/main.py"]
